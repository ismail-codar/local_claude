# Gemma-4-26B-A4B-it (MoE, ~4B aktif) + DFlash speculative decoding - cli.sh ayarlari
# Kaynak quickstart: https://github.com/Anbeeld/beellama.cpp/blob/main/docs/quickstart-gemma-4-31b-dflash.md
# Target GGUF: https://huggingface.co/unsloth/gemma-4-26B-A4B-it-GGUF
# Draft GGUF:  https://huggingface.co/Anbeeld/gemma-4-26B-A4B-it-DFlash-GGUF
#
# Kullanim:
#   sh ./cli.sh --env ./gemma4-dflash.env install
#   sh ./cli.sh --env ./gemma4-dflash.env start
#   sh ./cli.sh --env ./gemma4-dflash.env stop
#   sh ./cli.sh --env ./gemma4-dflash.env log
#
# Not:
#   26B-A4B MoE mimari: 26B toplam, ~4B aktif parametre.
#   DFlash draft modeli ayni 26B-A4B ailesi icin uretilmis.
#
# Bu profil hiz/kararlilik odakli:
#   - reasoning kapali
#   - context 32768
#   - prompt cache kapali
#   - daha stabil sampling
#   - DFlash cross ctx 1024 korunmus

INSTALL_REPO_URL=https://github.com/Anbeeld/beellama.cpp
INSTALL_BRANCH=main

# llama.cpp/beellama kurulum + calistirma dizini.
LLAMA_DIR=$ROOT_DIR/beellama.cpp

# --- Ag ---
HOST=0.0.0.0
PORT=8006

# Disa acik calistiriyorsan mutlaka API_KEY ver.
API_KEY=

# --- Target model ---
MODEL_URL=https://huggingface.co/unsloth/gemma-4-26B-A4B-it-GGUF/resolve/main/gemma-4-26B-A4B-it-UD-Q4_K_S.gguf
MODEL_FILE=$MODEL_DIR/gemma-4-26B-A4B-it-UD-Q4_K_S.gguf

# --- DFlash draft model ---
ENABLE_DFLASH=1
DRAFT_MODEL_URL=https://huggingface.co/Anbeeld/gemma-4-26B-A4B-it-DFlash-GGUF/resolve/main/gemma4-26b-a4b-it-dflash-IQ4_XS.gguf
DRAFT_MODEL_FILE=$MODEL_DIR/gemma4-26b-a4b-it-dflash-IQ4_XS.gguf

# Draft katmanlarinin tamami GPU'ya.
SPEC_DRAFT_NGL=99

# DFlash cross context.
# Loglarda target SWA=1024, draft SWA=2048 mismatch gorundugu icin 1024'te birakmak daha guvenli.
SPEC_DFLASH_CROSS_CTX=1024

# Istersen draft cihazi zorlayabilirsin. Bos birakilirsa llama.cpp CUDA0 secer.
# Ornek: SPEC_DRAFT_DEVICE=CUDA0
SPEC_DRAFT_DEVICE=

# --- Multimodal ---
# Hiz icin kapali. Vision gerekiyorsa 1 yap.
ENABLE_MMPROJ=0
MMPROJ_URL=https://huggingface.co/unsloth/gemma-4-26B-A4B-it-GGUF/resolve/main/mmproj-BF16.gguf
MMPROJ_FILE=$MODEL_DIR/gemma-4-26B-A4B-it-mmproj-BF16.gguf

# --- Context / batching ---
# Onceki 102400 uzun context, DFlash acceptance'i dusurebiliyor.
# Hiz ve DFlash verimi icin once 32768 ile test et.
CTX_SIZE=32768
PARALLEL_SLOTS=1
GPU_LAYERS=99
BATCH_SIZE=2048
UBATCH_SIZE=512
THREADS=0

# Prompt cache:
# Loglarda SWA/hybrid memory nedeniyle prompt cache tekrar kullanilamiyor.
# Bu yuzden cache save/update overhead'ini azaltmak icin kapali.
CACHE_RAM=0

# --- MTP kapali: spec-decoding DFlash uzerinden yapiliyor ---
ENABLE_MTP=0
SPEC_DRAFT_N_MAX=6

# --- KV cache ---
# Dengeli kalite/VRAM ayari.
CACHE_TYPE_K=q5_0
CACHE_TYPE_V=q4_1

# Daha agresif hiz/VRAM testi icin alternatif:
# CACHE_TYPE_K=q4_0
# CACHE_TYPE_V=q4_0

# --- Reasoning ---
# Hiz icin kapali.
# Onceki script default'u bos budget'i 4096'ya cevirebiliyordu; yeni cli.sh bunu duzeltiyor.
REASONING=off
REASONING_BUDGET=0
REASONING_FORMAT=

# --- Chat template ---
# Gemma gomulu template kullanilir.
CHAT_TEMPLATE_FILE=

# --- Sampling ---
# DFlash acceptance icin 1.0/0.95'e gore biraz daha stabil profil.
TEMP=0.7
TOP_K=40
TOP_P=0.9
MIN_P=0.0
REPEAT_PENALTY=

# --- Web UI / slots ---
ENABLE_WEBUI=1
ENABLE_SLOTS=1