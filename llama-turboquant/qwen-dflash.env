# Qwen3.6-35B-A3B (MoE, ~3B aktif) + DFlash speculative decoding - cli.sh ayarlari
# Kaynak fork:  https://github.com/Anbeeld/beellama.cpp (DFlash destekli llama.cpp)
# Target GGUF:  https://huggingface.co/unsloth/Qwen3.6-35B-A3B-GGUF
# Draft GGUF:   https://huggingface.co/Anbeeld/Qwen3.6-35B-A3B-DFlash-GGUF
#
# Kullanim:
#   ./cli.sh --env ./qwen-dflash.env install
#   ./cli.sh --env ./qwen-dflash.env start
#   ./cli.sh --env ./qwen-dflash.env stop
#   ./cli.sh --env ./qwen-dflash.env log
#
# Not: DFlash, ayri bir draft modeli ile spec-decoding yapar; modelin gomulu MTP
# katmanina ihtiyaci yoktur. Bu yuzden target olarak duz (MTP'siz) GGUF kullaniliyor.

INSTALL_REPO_URL=https://github.com/Anbeeld/beellama.cpp
INSTALL_BRANCH=main

# beellama.cpp kurulum + calistirma dizini.
# Duz atama: cli.sh L30 seed'inin uzerine yazar -> beellama.cpp dizinine kurar/calistirir.
LLAMA_DIR=$ROOT_DIR/beellama.cpp

# --- Ag ---
HOST=0.0.0.0
# Qwen 8001, LFM 8003, MiniCPM 8004, Gemma12B 8005, gemma4-dflash 8006 ile cakismamak icin
PORT=8007

# --- Target model (UD-Q5_K_XL ~27.2 GB; UD-Q4_K_XL daha serin / UD-Q6_K_XL daha kaliteli) ---
MODEL_URL=https://huggingface.co/unsloth/Qwen3.6-35B-A3B-GGUF/resolve/main/Qwen3.6-35B-A3B-UD-Q5_K_XL.gguf
MODEL_FILE=$MODEL_DIR/Qwen3.6-35B-A3B-UD-Q5_K_XL.gguf

# --- DFlash draft model (IQ4_XS en kucuk; Q4_K_M / Q5_K_M / Q6_K alternatifleri de var) ---
ENABLE_DFLASH=1
DRAFT_MODEL_URL=https://huggingface.co/Anbeeld/Qwen3.6-35B-A3B-DFlash-GGUF/resolve/main/qwen36-35b-a3b-dflash-IQ4_XS.gguf
DRAFT_MODEL_FILE=$MODEL_DIR/qwen36-35b-a3b-dflash-IQ4_XS.gguf
# Draft katmanlarinin tamami GPU'ya (quickstart: --spec-draft-ngl all)
SPEC_DRAFT_NGL=99
# Drafter'in gordugu target hidden-state token sayisi (quickstart: 1024)
SPEC_DFLASH_CROSS_CTX=1024

# --- Multimodal: Qwen3.6-35B-A3B vision destekliyor (gerekmiyorsa kapali birak) ---
ENABLE_MMPROJ=0
MMPROJ_URL=https://huggingface.co/unsloth/Qwen3.6-35B-A3B-GGUF/resolve/main/mmproj-F16.gguf
MMPROJ_FILE=$MODEL_DIR/mmproj-F16.gguf

# --- Context ---
# 27 GB model + DFlash draft + KV cache. 48GB L40S'te 131072 guvenli baslangic;
# VRAM musaitse 262144'e cikarilabilir, sikisirsa dusurulur.
CTX_SIZE=131072
PARALLEL_SLOTS=1
GPU_LAYERS=99
BATCH_SIZE=2048
UBATCH_SIZE=512
THREADS=0

# --- MTP kapali: cli.sh default'u 1; DFlash ile cakismamasi icin acikca 0 ---
ENABLE_MTP=0

# --- KV cache (beellama/standart quant; turboquant turbo4 tipleri bu fork'ta yok) ---
CACHE_TYPE_K=q5_0
CACHE_TYPE_V=q4_1

# --- Reasoning: Qwen3.6 <think> uretir -> deepseek formati ile reasoning_content'e ayrilir ---
REASONING=on
REASONING_BUDGET=4096
REASONING_FORMAT=deepseek

# --- Ozel chat template: gerek yok, gomulu Qwen template'i kullanilir ---
CHAT_TEMPLATE_FILE=

# --- Sampling (Qwen3 thinking modu onerilen degerleri) ---
TEMP=0.6
TOP_K=20
TOP_P=0.95
MIN_P=0.0
REPEAT_PENALTY=

# --- Web UI / slots / API key ---
ENABLE_WEBUI=1
ENABLE_SLOTS=1
API_KEY=
