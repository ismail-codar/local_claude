# EmbeddingGemma-300M - cli.sh embedding sunucusu ayarlari
# Kaynak GGUF: https://huggingface.co/unsloth/embeddinggemma-300m-GGUF
# Target GGUF: embeddinggemma-300M-Q8_0.gguf (~320 MB, 768 boyut, Matryoshka 512/256/128)
#
# Kullanim:
#   sh ./cli.sh --env ./embeddinggemma-300m.env install
#   sh ./cli.sh --env ./embeddinggemma-300m.env start
#   sh ./cli.sh --env ./embeddinggemma-300m.env stop
#   sh ./cli.sh --env ./embeddinggemma-300m.env log
#
# Not: Bu bir EMBEDDING modeli; metin uretmez. ENABLE_EMBEDDING=1 ile
# llama-server /v1/embeddings ve /embedding uclarini acar. Speculative decoding
# (MTP/DFlash), reasoning, sampling ve multimodal kapali.
#
# Istemci tarafi: EmbeddingGemma prompt prefiksleri bekler, orn:
#   sorgu  -> "task: search result | query: <metin>"
#   belge  -> "title: none | text: <metin>"

INSTALL_REPO_URL=https://github.com/TheTom/llama-cpp-turboquant.git
INSTALL_BRANCH=feature/turboquant-kv-cache

# turboquant kurulum + calistirma dizini.
LLAMA_DIR=$ROOT_DIR/llama-cpp-turboquant

# --- Ag ---
HOST=0.0.0.0
# Qwen 8001, LFM 8003, MiniCPM 8004, Gemma12B 8005, gemma4-dflash 8006,
# qwen-dflash 8007, qwopus27b-mtp 8008 ile cakismamak icin 8009.
PORT=8009

# Disa acik calistiriyorsan mutlaka API_KEY ver.
API_KEY=

# --- Target model (Q8_0 ~320 MB; embedding modeli icin Q8_0 onerilir) ---
MODEL_URL=https://huggingface.co/unsloth/embeddinggemma-300m-GGUF/resolve/main/embeddinggemma-300M-Q8_0.gguf
MODEL_FILE=$MODEL_DIR/embeddinggemma-300M-Q8_0.gguf

# --- Embedding modu ---
ENABLE_EMBEDDING=1
# EmbeddingGemma ortalama (mean) pooling kullanir.
POOLING_TYPE=mean
# Cikti vektorleri L2-normalize edilsin (2 = Euclidean/L2; -1 = normalize yok).
EMBD_NORMALIZE=2

# --- Speculative decoding: embedding modelinde kapali ---
ENABLE_MTP=0
ENABLE_DFLASH=0

# --- Multimodal: yok ---
ENABLE_MMPROJ=0

# --- Context / batching ---
# EmbeddingGemma 2048 token context destekler. Embedding modunda tum dizi
# tek ubatch'e sigmali, bu yuzden BATCH/UBATCH >= CTX_SIZE.
CTX_SIZE=2048
PARALLEL_SLOTS=1
GPU_LAYERS=99
BATCH_SIZE=2048
UBATCH_SIZE=2048
THREADS=0

# Prompt cache: embedding'te gereksiz, llama-server varsayilani birakildi.
CACHE_RAM=

# --- KV cache ---
# Embedding modeli token uretmez; turbo KV cache yerine duz f16 yeterli/guvenli.
CACHE_TYPE_K=f16
CACHE_TYPE_V=f16

# --- Reasoning: embedding modelinde anlamsiz, kapali ---
REASONING=
REASONING_BUDGET=
REASONING_FORMAT=

# --- Chat template: gerek yok ---
CHAT_TEMPLATE_FILE=

# --- Sampling: embedding'te kullanilmaz ---
TEMP=
TOP_K=
TOP_P=
MIN_P=
REPEAT_PENALTY=

# --- Web UI / slots / API key ---
# llama-ui sohbet arayuzudur (/v1/chat/completions cagirir); embedding modelinde
# generation ucu olmadigi icin calismaz -> kapali.
ENABLE_WEBUI=0
# /slots izleme ucu embedding'te de calisir, acik birakildi (istersen 0 yap).
ENABLE_SLOTS=1
