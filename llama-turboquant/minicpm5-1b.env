# MiniCPM5-1B (TurboQuant TQ4_1S GGUF) - cli.sh ayarlari
# Model karti: https://huggingface.co/openbmb/MiniCPM5-1B
# GGUF repo:   https://huggingface.co/rpopreapovle/MiniCPM5-1B-TQx_1S-GGUF
#
# Kullanim:
#   sh ./cli.sh --env ./minicpm5-1b.env start
#   sh ./cli.sh --env ./minicpm5-1b.env stop
#   sh ./cli.sh --env ./minicpm5-1b.env log
#
# Mimari: dense, ~1B parametre, salt-metin. Kucuk model -> dusuk VRAM, yuksek hiz.
# Quant: TQ4_1S (TurboQuant 4-bit) -> agirliklar zaten TurboQuant ile sikistirilmis.

# --- Ag ---
HOST=0.0.0.0
# Qwen 8001, LFM 8003 ile cakismamak icin farkli port
PORT=8004

# --- Model (TQ4_1S, TurboQuant 4-bit, ~0.7 GB) ---
MODEL_URL=https://huggingface.co/rpopreapovle/MiniCPM5-1B-TQx_1S-GGUF/resolve/main/minicpm5-TQ4_1S.gguf
MODEL_FILE=$MODEL_DIR/minicpm5-1B-TQ4_1S.gguf

# --- Multimodal: MiniCPM5-1B salt-metin, vision yok ---
ENABLE_MMPROJ=0

# --- Context (model karti: 131072) ---
CTX_SIZE=131072
PARALLEL_SLOTS=1
GPU_LAYERS=99
BATCH_SIZE=1024
UBATCH_SIZE=512
THREADS=0

# --- MTP: MiniCPM5-1B'de draft/MTP katmani yok -> kapali ---
ENABLE_MTP=0

# --- TurboQuant KV cache (model karti onerisi: K=f16, V=turbo4) ---
CACHE_TYPE_K=f16
CACHE_TYPE_V=turbo4

# --- Reasoning ---
# MiniCPM5 reasoning-capable ise <think> bloklarini reasoning_content'e ayir.
# Bos = model/llama.cpp varsayilani.
REASONING_BUDGET=
REASONING_FORMAT=deepseek

# --- Sampling (model karti onerisi: temp 0.9, top-p 0.95) ---
TEMP=0.9
TOP_P=0.95
TOP_K=
REPEAT_PENALTY=
MIN_P=

# --- Web UI / slots / API key ---
ENABLE_WEBUI=1
ENABLE_SLOTS=1
API_KEY=
