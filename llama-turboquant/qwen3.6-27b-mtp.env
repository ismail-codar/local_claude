# Qwen3.6-27B (dense) + gomulu MTP speculative decoding - cli.sh ayarlari
# Kaynak fork:  https://github.com/TheTom/llama-cpp-turboquant (MTP + turboquant KV cache)
# Target GGUF:  https://huggingface.co/unsloth/Qwen3.6-27B-MTP-GGUF
#
# Kullanim:
#   sh ./cli.sh --env ./qwen3.6-27b-mtp.env install
#   sh ./cli.sh --env ./qwen3.6-27b-mtp.env start
#   sh ./cli.sh --env ./qwen3.6-27b-mtp.env stop
#   sh ./cli.sh --env ./qwen3.6-27b-mtp.env log
#
# Not: MTP (Multi-Token Prediction) modelin GGUF'una gomuludur; DFlash gibi ayri bir
# draft modeline ihtiyac yoktur. Bu yuzden ENABLE_MTP=1, ENABLE_DFLASH=0.

INSTALL_REPO_URL=https://github.com/TheTom/llama-cpp-turboquant.git
INSTALL_BRANCH=feature/turboquant-kv-cache

# turboquant kurulum + calistirma dizini.
LLAMA_DIR=$ROOT_DIR/llama-cpp-turboquant

# --- Ag ---
HOST=0.0.0.0
# Qwen 8001, LFM 8003, MiniCPM 8004, Gemma12B 8005, gemma4-dflash 8006,
# qwen-dflash 8007, qwopus27b-mtp 8008 ile cakismamak icin 8009.
PORT=8009

# Disa acik calistiriyorsan mutlaka API_KEY ver.
API_KEY=

# --- Target model (UD-Q5_K_XL; daha serin icin UD-Q4_K_XL / daha kaliteli icin UD-Q6_K_XL) ---
MODEL_URL=https://huggingface.co/unsloth/Qwen3.6-27B-MTP-GGUF/resolve/main/Qwen3.6-27B-UD-Q5_K_XL.gguf
MODEL_FILE=$MODEL_DIR/Qwen3.6-27B-UD-Q5_K_XL.gguf

# --- Gomulu MTP speculative decoding ---
ENABLE_MTP=1
ENABLE_DFLASH=0
# Her adimda MTP'den cekilecek max taslak token sayisi.
SPEC_DRAFT_N_MAX=6

# --- Multimodal: vision destegi var (gerekmiyorsa kapali birak) ---
ENABLE_MMPROJ=0
MMPROJ_URL=https://huggingface.co/unsloth/Qwen3.6-27B-MTP-GGUF/resolve/main/mmproj-F16.gguf
MMPROJ_FILE=$MODEL_DIR/Qwen3.6-27B-mmproj-F16.gguf

# --- Context / batching ---
# 27B dense + KV cache. 48GB L40S'te 131072 guvenli baslangic;
# VRAM musaitse 262144'e cikarilabilir, sikisirsa dusurulur.
CTX_SIZE=131072
PARALLEL_SLOTS=1
GPU_LAYERS=99
BATCH_SIZE=2048
UBATCH_SIZE=512
THREADS=0

# Prompt cache: bos = llama-server varsayilani. Kapatmak icin 0 ver.
CACHE_RAM=

# --- TurboQuant KV cache ---
CACHE_TYPE_K=turbo4
CACHE_TYPE_V=turbo4

# --- Reasoning: Qwen3.6 <think> uretir -> deepseek formati ile reasoning_content'e ayrilir ---
REASONING=on
REASONING_BUDGET=4096
REASONING_FORMAT=deepseek

# --- Ozel chat template: gerek yok, gomulu Qwen template'i kullanilir ---
CHAT_TEMPLATE_FILE=

# --- Sampling (Qwen3 thinking modu onerilen degerleri) ---
TEMP=0.6
TOP_K=20
TOP_P=0.95
MIN_P=0.0
REPEAT_PENALTY=

# --- Web UI / slots / API key ---
ENABLE_WEBUI=1
ENABLE_SLOTS=1
