{
	admin off
	auto_https off
}

:7999 {
	log {
		output file access.log
		format json
	}

	@llama path /llama /llama/*
	handle @llama {
		uri strip_prefix /llama
		reverse_proxy localhost:8001
	}

	@searxng path /searxng /searxng/*
	handle @searxng {
		uri strip_prefix /searxng
		reverse_proxy localhost:3333
	}

	@localai path /localai /localai/*
	handle @localai {
		uri strip_prefix /localai
		reverse_proxy localhost:8000
	}

	handle {
		respond "caddy ok" 200
	}
}
