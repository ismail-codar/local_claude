# ── Proxy ayarları ──────────────────────────────
GATEWAY_PORT=8010
GATEWAY_TARGET_URL=http://localhost:8001

# ── Langfuse kimlik bilgileri ────────────────────
# https://cloud.langfuse.com → Settings → API Keys
LANGFUSE_PUBLIC_KEY=pk-lf-xxxxxxxxxxxxxxxxxxxx
LANGFUSE_SECRET_KEY=sk-lf-xxxxxxxxxxxxxxxxxxxx
LANGFUSE_HOST=https://cloud.langfuse.com
LANGFUSE_CURL_LOG=masked

# ── Süreç yönetimi ───────────────────────────────
# GATEWAY_PID_FILE=/tmp/proxy_gateway.pid
# GATEWAY_LOG_FILE=/tmp/proxy_gateway.log
